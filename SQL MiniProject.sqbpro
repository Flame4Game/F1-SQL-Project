<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="SQL MiniProject.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="797"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Drivers" custom_title="0" dock_id="1" table="4,7:mainDrivers"/><dock_state state="000000ff00000000fd0000000100000002000003db000002dbfc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000003db0000013200ffffff000003db0000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Drivers" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="226"/><column index="3" value="69"/><column index="4" value="280"/><column index="5" value="39"/><column index="6" value="39"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Fastest_Laps" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="1"/></sort><column_widths><column index="1" value="132"/><column index="2" value="202"/><column index="3" value="195"/><column index="4" value="78"/><column index="5" value="46"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Races" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="132"/><column index="2" value="93"/><column index="3" value="202"/><column index="4" value="195"/><column index="5" value="39"/><column index="6" value="93"/><column index="7" value="46"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">DELETE FROM Races
WHERE Year IS NULL;

DELETE FROM Fastest_Laps
WHERE Year IS NULL;

DELETE FROM Drivers
WHERE Year IS NULL;

-- Number of Race Wins per Constructor
SELECT Car, COUNT(*) AS Winners FROM Races
GROUP BY Car
ORDER BY Winners DESC;

-- Number of Total Points for Each Driver
SELECT Driver, SUM(Pts) AS Total_Points FROM Drivers
GROUP BY Driver
ORDER BY Total_Points DESC;

-- All-Time Leaderboard in Fastest Laps
SELECT Driver, COUNT(*) AS Number_Of_Fastest_Laps FROM Fastest_Laps
GROUP BY Driver
ORDER BY Number_Of_Fastest_Laps DESC;

-- Longest Tracks on Average by Lap Count, with Minimum 20 Races All Time
SELECT Grand_Prix, ROUND(AVG(Laps), 2) AS Average_Laps, COUNT(*) AS Number_Of_Races FROM Races
GROUP BY Grand_Prix HAVING Number_Of_Races &gt; 20
ORDER BY Average_Laps DESC;

-- Fastest Laps in Milliseconds after 2000
SELECT b.Fastest_Lap_MS AS &quot;Fastest Lap in MS&quot;, a.Driver, a.Nationality, a.Year, a.Pos as &quot;Position that Year&quot;, a.Pts AS &quot;Points that Year&quot;, b.Grand_Prix, b.Car FROM
(SELECT Pos, Driver, Year, Nationality, Car, Pts FROM Drivers) AS a
INNER JOIN 
(SELECT Grand_Prix, Driver, Year, Car,
    (CAST(SUBSTR(Fastest_Lap, 1, INSTR(Fastest_Lap, ':') - 1) AS INTEGER) * 60000 +
     CAST(SUBSTR(Fastest_Lap, INSTR(Fastest_Lap, ':') + 1) AS REAL) * 1000
    ) AS Fastest_Lap_MS
FROM Fastest_Laps) AS b
ON a.Driver = b.Driver AND a.Year = b.Year
WHERE a.Year &gt; 2000
ORDER BY &quot;Fastest Lap in MS&quot; ASC;

-- Longest Races for each Race Winner All Time
SELECT CONCAT(Grand_Prix, ' ', Year) AS Race, &quot;Date&quot;, Winner, Car, Laps, &quot;Time&quot;,
	RANK() OVER(PARTITION BY Winner ORDER BY Laps DESC) as Laps_Rank FROM Races;

-- All Time Constructors' Leaderboard by Points
WITH Driver_Car AS (
	SELECT CONCAT(Driver, ' ', Car) as Driver_Car, Car AS Constructor, Pts, Year
	FROM Drivers
)
SELECT Constructor, SUM(Pts) AS Total_Points_For_Constructor, COUNT(DISTINCT Driver_Car) AS Unique_Drivers FROM Driver_Car
GROUP BY Constructor HAVING Total_Points_For_Constructor &gt; 200
ORDER BY Total_Points_For_Constructor DESC;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
